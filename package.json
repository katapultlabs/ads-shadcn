  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "build": "vite build",
    "mcp": "node mcp-server/index.js",
