    "generate:rich-meta": "node scripts/generate-rich-meta-module.mjs",
    "quality": "node scripts/generate-quality-report.mjs",
    "generate": "npm run generate:theme && npm run generate:icons && npm run apply:shadcn-base && npm run enrich:components && npm run generate:rich-meta && npm run quality",
    "validate:specs": "node scripts/validate-specs.mjs",
    "verify:tokens": "node scripts/verify-tokens.mjs",
    "verify:drift": "node scripts/verify-drift.mjs",
    "lint:ui": "node scripts/lint-ui.mjs",
    "eval": "node scripts/eval.mjs",
    "generate:inert-controls": "node scripts/generate-inert-controls.mjs",
    "verify:renders": "node scripts/verify-renders.mjs",
    "baseline:capture": "node scripts/visual-baseline.mjs --capture",
    "verify:visual": "node scripts/visual-baseline.mjs",
    "test": "npm run validate:specs && npm run verify:tokens && npm run verify:drift && npm run build && npm run verify:renders"
  },
